# Copy to .env and adjust paths. Used by loaders and scripts.

# Root directory containing Spider release (unzipped): expects database/, train_spider.json, etc.
SPIDER_DATA_DIR=./data/spider

# Optional: override Chroma persistence path (defaults from configs/default.yaml)
# CHROMA_PATH=./data/chroma_schema

# Optional: Hugging Face cache directory
# HF_HOME=./data/hf_cache
